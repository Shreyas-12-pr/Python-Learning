class Solution:
    def canReach(self, s: str, minJump: int, maxJump: int) -> bool:
        n = len(s)

        reachable = [False] * n
        reachable[0] = True

        pre = 0

        for i in range(1, n):
            if i >= minJump:
                pre += reachable[i - minJump]

            if i > maxJump:
                pre -= reachable[i - maxJump - 1]

            reachable[i] = (pre > 0 and s[i] == '0')

        return reachable[-1]