from typing import List

class Solution:
    def maxIceCream(self, costs: List[int], coins: int) -> int:
        max_cost = max(costs)

        freq = [0] * (max_cost + 1)

        for cost in costs:
            freq[cost] += 1

        bars = 0

        for cost in range(1, max_cost + 1):
            if freq[cost] == 0:
                continue

            total_cost = cost * freq[cost]

            if coins >= total_cost:
                bars += freq[cost]
                coins -= total_cost
            else:
                bars += coins // cost
                break

        return bars